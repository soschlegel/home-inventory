generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ItemCondition {
  NEW
  GOOD
  WORN
  BROKEN
}

enum UserRole {
  EDITOR
  VIEWER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         UserRole @default(EDITOR)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Einheitenliste – geteilt zwischen allen Nutzern, dient als Vorschlagsliste
model Unit {
  id           String   @id @default(cuid())
  key          String   @unique
  name         String   @unique
  translations Json?
  createdAt    DateTime @default(now())
}

// Benutzerdefinierter Container-Typ – geteilt zwischen allen Nutzern
model ContainerType {
  id           String     @id @default(cuid())
  key          String?    @unique
  name         String     @unique
  translations Json?
  icon         String?
  color        String?
  locations    Location[]
  createdAt    DateTime   @default(now())
}

// Raum im Haus – geteilt zwischen allen Nutzern
model Room {
  id           String     @id @default(cuid())
  key          String?    @unique
  name         String
  translations Json?
  description  String?
  icon         String?
  locations    Location[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

// Aufbewahrungsort / Container (beliebig verschachtelbar)
model Location {
  id              String         @id @default(cuid())
  name            String
  description     String?
  containerTypeId String?
  containerType   ContainerType? @relation(fields: [containerTypeId], references: [id], onDelete: SetNull)
  roomId          String
  room            Room           @relation(fields: [roomId], references: [id], onDelete: Cascade)
  parentId        String?
  parent          Location?      @relation("LocationChildren", fields: [parentId], references: [id])
  children        Location[]     @relation("LocationChildren")
  items           Item[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

// Ein Gegenstand an einem Aufbewahrungsort
model Item {
  id            String         @id @default(cuid())
  name          String
  description   String?
  quantity      Float          @default(1)
  unit          String?
  minQuantity   Float?
  condition     ItemCondition?
  imageUrl      String?
  purchaseUrl   String?
  purchasePrice Float?
  purchaseDate  DateTime?
  warrantyUntil     DateTime?
  expiryDate        DateTime?
  expiryWarningDays Int?
  serialNumber      String?
  barcode           String?
  locationId    String
  location      Location       @relation(fields: [locationId], references: [id], onDelete: Cascade)
  tags          ItemTag[]
  lendings      Lending[]
  documents     ItemDocument[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model ItemDocument {
  id           String   @id @default(cuid())
  itemId       String
  item         Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  originalName String
  url          String
  mimeType     String?
  size         Int?
  createdAt    DateTime @default(now())
}

model Lending {
  id         String    @id @default(cuid())
  itemId     String
  item       Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)
  lentTo     String
  lentAt     DateTime  @default(now())
  returnedAt DateTime?
  note       String?
  createdAt  DateTime  @default(now())
}

model Tag {
  id           String    @id @default(cuid())
  key          String    @unique
  name         String    @unique
  translations Json?
  items        ItemTag[]
  createdAt    DateTime  @default(now())
}

// Anwendungseinstellungen (key-value)
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model ItemTag {
  itemId String
  tagId  String
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([itemId, tagId])
}
