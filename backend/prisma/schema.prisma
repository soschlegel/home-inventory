generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ItemCondition {
  NEW
  GOOD
  WORN
  BROKEN
}

enum UserRole {
  EDITOR
  VIEWER
}

model User {
  id                String     @id @default(cuid())
  email             String     @unique
  passwordHash      String
  name              String?
  role              UserRole   @default(EDITOR)
  assignedInstances Instance[]
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
}

// Einheitenliste – geteilt zwischen allen Nutzern, dient als Vorschlagsliste
model Unit {
  id           String   @id @default(cuid())
  key          String   @unique
  name         String   @unique
  translations Json?
  createdAt    DateTime @default(now())
}

// Benutzerdefinierter Container-Typ – geteilt zwischen allen Nutzern
model ContainerType {
  id           String     @id @default(cuid())
  key          String?    @unique
  name         String     @unique
  translations Json?
  icon         String?
  color        String?
  locations    Location[]
  createdAt    DateTime   @default(now())
}

// Raum im Haus – geteilt zwischen allen Nutzern
model Room {
  id           String     @id @default(cuid())
  key          String?    @unique
  name         String
  translations Json?
  description  String?
  icon         String?
  locations    Location[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

// Aufbewahrungsort / Container (beliebig verschachtelbar)
model Location {
  id              String         @id @default(cuid())
  name            String
  description     String?
  containerTypeId String?
  containerType   ContainerType? @relation(fields: [containerTypeId], references: [id], onDelete: SetNull)
  roomId          String
  room            Room           @relation(fields: [roomId], references: [id], onDelete: Cascade)
  parentId        String?
  parent          Location?      @relation("LocationChildren", fields: [parentId], references: [id])
  children        Location[]     @relation("LocationChildren")
  instances       Instance[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

// Produkt = Stammdaten (was ist dieser Gegenstand?)
model Product {
  id          String            @id @default(cuid())
  name        String
  description String?
  imageUrl    String?
  barcode     String?
  purchaseUrl       String?
  minQuantity       Float?
  expiryWarningDays Int?
  tags              ProductTag[]
  documents   ProductDocument[]
  instances   Instance[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model ProductTag {
  productId String
  tagId     String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
}

model ProductDocument {
  id           String   @id @default(cuid())
  productId    String
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  originalName String
  url          String
  mimeType     String?
  size         Int?
  createdAt    DateTime @default(now())
}

// Exemplar = ein konkretes physisches Objekt
model Instance {
  id                String             @id @default(cuid())
  productId         String
  product           Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity          Float              @default(1)
  unit              String?
  condition         ItemCondition?
  serialNumber      String?
  purchaseDate      DateTime?
  purchasePrice     Float?
  warrantyUntil     DateTime?
  expiryDate        DateTime?
  locationId        String?
  location          Location?          @relation(fields: [locationId], references: [id], onDelete: SetNull)
  assignedUserId    String?
  assignedUser      User?              @relation(fields: [assignedUserId], references: [id], onDelete: SetNull)
  documents         InstanceDocument[]
  lendings          Lending[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model InstanceDocument {
  id           String   @id @default(cuid())
  instanceId   String
  instance     Instance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  originalName String
  url          String
  mimeType     String?
  size         Int?
  createdAt    DateTime @default(now())
}

model Lending {
  id         String    @id @default(cuid())
  instanceId String
  instance   Instance  @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  lentTo     String
  lentAt     DateTime  @default(now())
  returnedAt DateTime?
  note       String?
  createdAt  DateTime  @default(now())
}

model Tag {
  id           String       @id @default(cuid())
  key          String       @unique
  name         String       @unique
  translations Json?
  products     ProductTag[]
  createdAt    DateTime     @default(now())
}

// Anwendungseinstellungen (key-value)
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
