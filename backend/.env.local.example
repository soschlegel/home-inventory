# Lokales Testen mit SQLite (kein Docker/PostgreSQL nötig)
#
# 1. Diese Datei als .env.local speichern
# 2. npm run db:setup:sqlite  (Schema erstellen + Prisma Client generieren)
# 3. npm run db:seed          (optional: Beispieldaten einspielen)
# 4. npm run dev              (Backend starten)
#
# .env.local überschreibt .env – PostgreSQL-Konfiguration bleibt unangetastet.

DATABASE_URL=file:./dev.db
